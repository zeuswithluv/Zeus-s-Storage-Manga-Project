# VITE_LOGO_URL: Link trực tiếp đến ảnh logo (ImgBB, v.v.)
VITE_LOGO_URL="YOUR_LOGO_URL_HERE"

# Firebase Configuration (Dùng cho Production/GitHub - Thêm vào Cloudflare/Vercel Environment Variables)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# ImgBB API Key (Dùng cho Server-side Proxy - KHÔNG CÓ VITE_ prefix để bảo mật)
# Trên Vercel: Thêm vào Environment Variables
# Trên Cloudflare Pages: Thêm vào Settings -> Variables -> Environment variables
IMGBB_API_KEY=YOUR_IMGBB_API_KEY_HERE

# ImgBB API Key (Dùng cho Client-side fallback - CÓ VITE_ prefix)
VITE_IMGBB_API_KEY=YOUR_IMGBB_API_KEY_HERE

# Admin Email (Dùng để cấp quyền Admin cho tài khoản của bạn)
VITE_ADMIN_EMAIL=admin@example.com

# Firebase Configuration (Dùng khi deploy lên GitHub/Vercel để bảo mật)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=
